# Install vim-plug if missing; Vim auto-installs missing checkouts when vim-plug is present.
if [[ ! -f "$HOME/.vim/autoload/plug.vim" ]]; then
    if command -v curl >/dev/null 2>&1; then
        if ! curl -fLo "$HOME/.vim/autoload/plug.vim" --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim; then
            echo "WARN: failed to install vim-plug" >&2
        fi
    else
        echo "WARN: curl not found; skipping vim-plug install" >&2
    fi
fi
